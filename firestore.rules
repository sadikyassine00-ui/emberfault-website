rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Reference Helpers
    function existing() { return resource.data; }
    function incoming() { return request.resource.data; }
    function isSignedIn() { return request.auth != null; }
    
    // Auth Helpers
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdminEmail() { 
      return isSignedIn() && 
             request.auth.token.email == "yassinesadik0@gmail.com" && 
             request.auth.token.email_verified == true; 
    }
    
    // Validation Helpers
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.keys().size() <= 4 &&
             data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 256 &&
             data.role is string && (data.role == "user" || data.role == "admin");
    }

    function isValidStats(data) {
      return data.keys().hasAll(['userId', 'blocksBuilt', 'blocksDestroyed', 'particlesShredded', 'updatedAt']) &&
             data.keys().size() <= 5 &&
             data.userId is string && data.userId.size() <= 128 &&
             data.blocksBuilt is number &&
             data.blocksDestroyed is number &&
             data.particlesShredded is number &&
             data.updatedAt is timestamp;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) &&
                       isValidUser(incoming()) &&
                       incoming().uid == userId &&
                       incoming().role == "user" &&
                       incoming().email == request.auth.token.email;
      allow update: if isOwner(userId) &&
                       isValidUser(incoming()) &&
                       incoming().uid == existing().uid &&
                       incoming().email == existing().email &&
                       incoming().role == existing().role &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['displayName']);
    }

    match /stats/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) &&
                       isValidStats(incoming()) &&
                       incoming().userId == userId &&
                       incoming().updatedAt == request.time;
      allow update: if isOwner(userId) &&
                       isValidStats(incoming()) &&
                       incoming().userId == existing().userId &&
                       incoming().updatedAt == request.time &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['blocksBuilt', 'blocksDestroyed', 'particlesShredded', 'updatedAt']);
    }

    match /leads/{leadId} {
      allow create: if true;
      allow read, delete: if isAdminEmail();
    }

    match /visits/{visitId} {
      allow create: if true;
      allow read: if isAdminEmail();
    }
  }
}
